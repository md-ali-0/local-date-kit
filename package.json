{
    "name": "local-date-kit",
    "version": "1.2.5",
    "type": "module",
    "description": "A modular toolkit for converting Gregorian dates into local calendar formats",
    "main": "dist/index.js",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "types": "dist/index.d.ts",
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
        "build": "pnpm run clean && tsc",
        "dev": "nodemon --watch src --ext ts --exec \"pnpm run build && node dist/index.js\"",
        "prepublishOnly": "pnpm run build",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "author": {
        "name": "Mohammad Ali",
        "email": "md.ali.office@gmail.com",
        "url": "https://md-ali.vercel.app"
    },
    "license": "ISC",
    "homepage": "https://github.com/md-ali-0/local-date-kit#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/md-ali-0/local-date-kit.git"
    },
    "bugs": {
        "url": "https://github.com/md-ali-0/local-date-kit/issues"
    },
    "funding": {
        "type": "individual",
        "url": "https://md-ali.vercel.app"
    },
    "keywords": [
        "date",
        "calendar",
        "local-calendar",
        "bangla",
        "hijri",
        "islamic",
        "indian",
        "japanese",
        "thai-buddhist",
        "roc",
        "date-conversion",
        "typescript"
    ],
    "packageManager": "pnpm@10.18.1",
    "engines": {
        "node": ">=18"
    },
    "publishConfig": {
        "access": "public"
    },
    "sideEffects": false,
    "devDependencies": {
        "@types/node": "^24.5.2",
        "nodemon": "^3.1.14",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    }
}
